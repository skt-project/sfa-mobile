{
  "name": "sfa-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "expo": "~57.0.2",
    "expo-camera": "^57.0.0",
    "expo-crypto": "^57.0.0",
    "expo-file-system": "^57.0.0",
    "expo-image-picker": "^57.0.2",
    "expo-location": "^57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-secure-store": "^57.0.0",
    "expo-sqlite": "^57.0.0",
    "expo-status-bar": "~57.0.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/react-native": "^0.72.8",
    "babel-preset-expo": "^57.0.1",
    "detox": "^20.51.4",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "postinstall": "patch-package || true && node scripts/patch-cmake.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:e2e:build": "detox build -c android.emu.debug",
    "test:e2e": "detox test -c android.emu.debug __tests__/e2e",
    "test:e2e:device": "detox test -c android.device.debug __tests__/e2e"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/unit/**/*.test.ts",
      "**/__tests__/unit/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|zustand|@tanstack))"
    ],
    "moduleNameMapper": {
      "^expo-crypto$": "<rootDir>/__mocks__/expo-crypto.js",
      "^expo-sqlite$": "<rootDir>/__mocks__/expo-sqlite.js"
    }
  },
  "private": true
}
